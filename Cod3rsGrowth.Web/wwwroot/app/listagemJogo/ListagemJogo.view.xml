<mvc:View
    controllerName="ui5.codersgrowth.app.listagemJogo.ListagemJogo"
    displayBlock="true"
    xmlns:u="sap.ui.unified"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    xmlns:s="sap.f.semantic"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table"
    xmlns:uxap="sap.uxap"
    xmlns="sap.m"
    height="100%"
    busyIndicatorDelay="0">
    <f:FlexibleColumnLayout
        layout="OneColumn"
        id="idLayout"
        >
        <f:beginColumnPages>
            <core:Fragment fragmentName="ui5.codersgrowth.app.listagemJogo.fragmentos.Lista" type="XML" />
        </f:beginColumnPages>
        <f:midColumnPages>
        <core:Fragment fragmentName="ui5.codersgrowth.app.listagemJogo.fragmentos.Detalhes" type="XML" />
        </f:midColumnPages>
    </f:FlexibleColumnLayout>
</mvc:View>